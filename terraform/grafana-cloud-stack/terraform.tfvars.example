# Copy to terraform.tfvars (gitignored) and fill in, or pass via -var /
# TF_VAR_* env vars.

# Create this token once in the Grafana Cloud portal - see variables.tf for
# the required scopes. Prefer TF_VAR_grafana_cloud_api_token over committing
# it here, even to a gitignored file.
# grafana_cloud_api_token = "glc_..."

# The slug is generated automatically ("<prefix><random>"); override the prefix
# only if you want a different subdomain stem.
# stack_slug_prefix = "jenkins2026obs"

# region_slug = "prod-eu-west-3"
