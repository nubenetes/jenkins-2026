{
  "apiVersion": "dashboard.grafana.app/v1",
  "kind": "Dashboard",
  "metadata": {
    "name": "jenkins2026-microservices-overview",
    "annotations": {
      "grafana.app/folder": "jenkins-2026"
    }
  },
  "spec": {
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": {
            "type": "grafana",
            "uid": "-- Grafana --"
          },
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
      {
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "id": 100,
        "panels": [],
        "title": "Microservices Services - $deployment_environment",
        "type": "row"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "description": "HTTP server request rate per service (Micrometer/OTel metric http_server_request_duration_seconds_count, exported by the Spring Boot Actuator + OTel Java agent auto-instrumentation - see helm/microservices/templates/instrumentation.yaml), split by service_name and deployment_environment (stable=master branch in namespace microservices, develop=develop branch in namespace microservices-develop).",
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "fillOpacity": 15
            },
            "unit": "reqps"
          },
          "overrides": []
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 1
        },
        "id": 1,
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          },
          "tooltip": {
            "mode": "multi"
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${DS_PROMETHEUS}"
            },
            "expr": "sum by (service_name, http_response_status_code) (rate(http_server_request_duration_seconds_count{deployment_environment=\"$deployment_environment\"}[5m]))",
            "legendFormat": "{{service_name}} [{{http_response_status_code}}]",
            "refId": "A"
          }
        ],
        "title": "HTTP Request Rate by Service",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "description": "5xx response rate per service - rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m]).",
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "fillOpacity": 15
            },
            "unit": "reqps"
          },
          "overrides": [
            {
              "matcher": {
                "id": "byType",
                "options": "number"
              },
              "properties": [
                {
                  "id": "color",
                  "value": {
                    "fixedColor": "red",
                    "mode": "fixed"
                  }
                }
              ]
            }
          ]
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 1
        },
        "id": 2,
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          },
          "tooltip": {
            "mode": "multi"
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${DS_PROMETHEUS}"
            },
            "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{deployment_environment=\"$deployment_environment\", http_response_status_code=~\"5..\"}[5m]))",
            "legendFormat": "{{service_name}}",
            "refId": "A"
          }
        ],
        "title": "5xx Error Rate by Service",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "description": "p95 server-side latency per service - histogram_quantile over http_server_request_duration_seconds_bucket.",
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "fillOpacity": 10
            },
            "unit": "s"
          },
          "overrides": []
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 9
        },
        "id": 3,
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          },
          "tooltip": {
            "mode": "multi"
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${DS_PROMETHEUS}"
            },
            "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{deployment_environment=\"$deployment_environment\"}[5m])))",
            "legendFormat": "{{service_name}} p95",
            "refId": "A"
          }
        ],
        "title": "HTTP Request Duration (p95)",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "description": "JVM heap usage per service - jvm_memory_used_bytes{jvm_memory_type=\"heap\"}.",
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "fillOpacity": 15,
              "stacking": {
                "mode": "normal"
              }
            },
            "unit": "bytes"
          },
          "overrides": []
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 9
        },
        "id": 4,
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          },
          "tooltip": {
            "mode": "multi"
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "${DS_PROMETHEUS}"
            },
            "expr": "sum by (service_name) (jvm_memory_used_bytes{deployment_environment=\"$deployment_environment\", jvm_memory_type=\"heap\"})",
            "legendFormat": "{{service_name}}",
            "refId": "A"
          }
        ],
        "title": "JVM Heap Usage by Service",
        "type": "timeseries"
      },
      {
        "collapsed": false,
        "gridPos": {
          "h": 1,
          "w": 24,
          "x": 0,
          "y": 17
        },
        "id": 101,
        "panels": [],
        "title": "Traces & Logs",
        "type": "row"
      },
      {
        "datasource": {
          "type": "tempo",
          "uid": "${DS_TEMPO}"
        },
        "description": "Recent traces across all Microservices services for the selected environment. Each request through microservices-angular -> api-gateway -> downstream microservices is a single trace (W3C traceparent propagated end-to-end, see resources/angular/otel-web.js and helm/microservices/templates/instrumentation.yaml).",
        "fieldConfig": {
          "defaults": {},
          "overrides": []
        },
        "gridPos": {
          "h": 9,
          "w": 24,
          "x": 0,
          "y": 18
        },
        "id": 5,
        "targets": [
          {
            "datasource": {
              "type": "tempo",
              "uid": "${DS_TEMPO}"
            },
            "query": "{resource.deployment.environment = \"$deployment_environment\"}",
            "queryType": "traceql",
            "refId": "A"
          }
        ],
        "title": "Microservices Traces",
        "type": "traces"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI}"
        },
        "description": "Application logs for the selected environment's namespace (microservices / microservices-develop). Lines containing trace_id=<hex> can be opened directly in Tempo via the Loki datasource's derived field.",
        "fieldConfig": {
          "defaults": {},
          "overrides": []
        },
        "gridPos": {
          "h": 9,
          "w": 24,
          "x": 0,
          "y": 27
        },
        "id": 6,
        "options": {
          "dedupStrategy": "none",
          "enableLogDetails": true,
          "prettifyLogMessage": false,
          "showLabels": false,
          "showTime": true,
          "sortOrder": "Descending",
          "wrapLogMessage": true
        },
        "targets": [
          {
            "datasource": {
              "type": "loki",
              "uid": "${DS_LOKI}"
            },
            "expr": "{k8s_namespace_name=~\"microservices.*\"} | json | line_format \"{{.message}}\"",
            "refId": "A"
          }
        ],
        "title": "Microservices Pod Logs",
        "type": "logs"
      }
    ],
    "refresh": "30s",
    "schemaVersion": 39,
    "tags": [
      "jenkins-2026",
      "microservices"
    ],
    "templating": {
      "list": [
        {
          "hide": 0,
          "includeAll": false,
          "label": "Prometheus / Mimir",
          "multi": false,
          "name": "DS_PROMETHEUS",
          "options": [],
          "query": "prometheus",
          "queryValue": "",
          "refresh": 1,
          "regex": "",
          "skipUrlSync": false,
          "type": "datasource"
        },
        {
          "hide": 0,
          "includeAll": false,
          "label": "Loki",
          "multi": false,
          "name": "DS_LOKI",
          "options": [],
          "query": "loki",
          "queryValue": "",
          "refresh": 1,
          "regex": "",
          "skipUrlSync": false,
          "type": "datasource"
        },
        {
          "hide": 0,
          "includeAll": false,
          "label": "Tempo",
          "multi": false,
          "name": "DS_TEMPO",
          "options": [],
          "query": "tempo",
          "queryValue": "",
          "refresh": 1,
          "regex": "",
          "skipUrlSync": false,
          "type": "datasource"
        },
        {
          "current": {
            "text": "stable",
            "value": "stable"
          },
          "hide": 0,
          "includeAll": false,
          "label": "Environment",
          "multi": false,
          "name": "deployment_environment",
          "options": [
            {
              "selected": true,
              "text": "stable",
              "value": "stable"
            },
            {
              "selected": false,
              "text": "develop",
              "value": "develop"
            }
          ],
          "query": "stable,develop",
          "queryValue": "",
          "skipUrlSync": false,
          "type": "custom"
        }
      ]
    },
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {},
    "timezone": "",
    "title": "jenkins-2026 / Microservices Overview",
    "uid": "jenkins2026-microservices-overview",
    "version": 1,
    "weekStart": "",
    "folderUID": "jenkins-2026"
  }
}
