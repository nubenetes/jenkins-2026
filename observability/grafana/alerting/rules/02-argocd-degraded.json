{
  "uid": "j2026-argocd-degraded",
  "title": "ArgoCD Application Degraded",
  "ruleGroup": "jenkins-2026",
  "folderUID": "jenkins-2026-alerts",
  "condition": "threshold",
  "for": "5m",
  "noDataState": "NoData",
  "execErrState": "Error",
  "labels": {
    "severity": "warning",
    "project": "jenkins-2026"
  },
  "annotations": {
    "summary": "ArgoCD application {{ $labels.name }} is Degraded",
    "description": "ArgoCD app {{ $labels.name }} has health_status=Degraded for more than 5 minutes. Check sync errors in the ArgoCD UI."
  },
  "data": [
    {
      "refId": "query",
      "relativeTimeRange": { "from": 300, "to": 0 },
      "datasourceUid": "grafanacloud-prom",
      "model": {
        "expr": "argocd_app_info{health_status=\"Degraded\",namespace=\"argocd\"} == 1",
        "refId": "query",
        "instant": true
      }
    },
    {
      "refId": "threshold",
      "relativeTimeRange": { "from": 0, "to": 0 },
      "datasourceUid": "-100",
      "model": {
        "conditions": [
          {
            "evaluator": { "params": [0], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["query"] },
            "reducer": { "params": [], "type": "last" },
            "type": "query"
          }
        ],
        "refId": "threshold",
        "type": "classic_conditions"
      }
    }
  ]
}
