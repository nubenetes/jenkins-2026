{
  "uid": "j2026-jvm-heap-high",
  "title": "JVM Heap Usage Above 85%",
  "ruleGroup": "jenkins-2026",
  "folderUID": "jenkins-2026",
  "condition": "threshold",
  "for": "5m",
  "noDataState": "NoData",
  "execErrState": "Error",
  "labels": {
    "severity": "warning",
    "project": "jenkins-2026"
  },
  "annotations": {
    "summary": "JVM heap usage above 85% for {{ $labels.service_name }}",
    "description": "Service {{ $labels.service_name }} JVM heap is above 85% for 5+ minutes. Risk of OOM or GC pressure."
  },
  "data": [
    {
      "refId": "query",
      "relativeTimeRange": { "from": 300, "to": 0 },
      "datasourceUid": "grafanacloud-prom",
      "model": {
        "expr": "(jvm_memory_used_bytes{jvm_memory_type=\"heap\",service_namespace=\"microservices\"} / jvm_memory_limit_bytes{jvm_memory_type=\"heap\",service_namespace=\"microservices\"}) > 0.85",
        "refId": "query",
        "instant": true
      }
    },
    {
      "refId": "threshold",
      "relativeTimeRange": { "from": 0, "to": 0 },
      "datasourceUid": "-100",
      "model": {
        "conditions": [
          {
            "evaluator": { "params": [0], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["query"] },
            "reducer": { "params": [], "type": "last" },
            "type": "query"
          }
        ],
        "refId": "threshold",
        "type": "classic_conditions"
      }
    }
  ]
}
