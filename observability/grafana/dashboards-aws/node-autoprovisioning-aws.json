    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Non-Spot nodes \u00e2\u20ac\u201d the long-lived jenkins-2026-pool hosting ArgoCD/Jenkins/observability/CNPG.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "unit": "none"
        },
        "overrides": []
