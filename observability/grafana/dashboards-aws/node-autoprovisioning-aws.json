      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "count(kube_node_spec_taint{key=\"cloud.google.com/gke-spot\"}) or vector(0)",
          "legendFormat": "Spot (NAP)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
