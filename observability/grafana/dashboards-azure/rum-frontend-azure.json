{
  "uid": "jenkins2026-rum-frontend",
  "title": "CI-CD Frontend RUM (Angular / Faro)",
  "tags": [
    "jenkins-2026",
    "rum",
    "frontend",
    "faro"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "refresh": "30s",
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "appinsights",
        "label": "Application Insights",
        "type": "query",
        "datasource": {
          "type": "grafana-azure-monitor-datasource",
          "uid": "azure-monitor-oob"
        },
        "query": {
          "queryType": "Azure Resource Graph",
          "azureResourceGraph": {
            "query": "resources | where type =~ 'microsoft.insights/components' | project id | order by id asc"
          }
        },
        "refresh": 1,
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "current": {},
        "options": []
      },
      {
        "name": "operation_id",
        "label": "operation_Id (trace correlation)",
        "type": "textbox",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "hide": 0
      },
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus / Mimir",
        "current": {
          "text": "grafanacloud-prom",
          "value": "grafanacloud-prom",
          "selected": true
        },
        "options": [],
        "includeAll": false,
        "multi": false,
        "hide": 0
      },
      {
        "name": "deployment_environment",
        "type": "custom",
        "label": "Environment",
        "query": "stable,develop",
        "current": {
          "text": "develop",
          "value": "develop"
        },
        "options": [
          {
            "selected": false,
            "text": "stable",
            "value": "stable"
          },
          {
            "selected": true,
            "text": "develop",
            "value": "develop"
          }
        ],
        "includeAll": false,
        "multi": false
      },
      {
        "name": "app",
        "label": "Faro app",
        "type": "custom",
        "query": "angular-gateway",
        "current": {
          "text": "angular-gateway",
          "value": "angular-gateway"
        },
        "options": [
          {
            "text": "angular-gateway",
            "value": "angular-gateway",
            "selected": true
          }
        ],
        "includeAll": false,
        "multi": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "**Frontend RUM (Real User Monitoring) for the Angular SPA via Grafana Faro.** The `faro` receiver + traces/logs pipeline are **live** in the otel-collector (browser \u2192 collector \u2192 Grafana Cloud). Panels populate **once the Angular app is instrumented with the Faro Web SDK** \u2014 see the *Frontend observability roadmap* in `docs/202`. Data model: Faro beacon \u2192 OTLP \u2192 Loki (labels `service_name`=Faro app, `deployment_environment`, `kind`\u2208{log,measurement,exception,event}) + Tempo (browser spans). Web-Vitals thresholds follow Google's good/needs-improvement/poor bands."
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "panels": []
    },
    {
      "id": 3,
      "type": "table",
      "title": "Sessions",
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "azure-monitor-oob"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "azure-monitor-oob"
          },
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "resources": [
              "${appinsights}"
            ],
            "query": "traces\n| where '${operation_id}' == '' or operation_Id == '${operation_id}'\n| project timestamp, severityLevel, cloud_RoleName, operation_Id, message\n| order by timestamp desc",
            "dashboardTime": true,
            "resultFormat": "table"
          },
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "operation_Id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Correlate: filter this trace (operation_Id)",
                    "url": "?var-operation_id=${__value.raw}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      }
    },
