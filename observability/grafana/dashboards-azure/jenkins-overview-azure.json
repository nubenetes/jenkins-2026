        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "100 * sum(rate(ci_pipeline_run_completed_total{ci_pipeline_run_result=\"SUCCESS\"}[$__rate_interval])) / sum(rate(ci_pipeline_run_completed_total[$__rate_interval]))",
