        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{deployment_environment=\"$deployment_environment\", service_name=~\"$service_name\", http_response_status_code=~\"5..\"}[$__rate_interval])) or (sum by (service_name) (rate(http_server_request_duration_seconds_count{deployment_environment=\"$deployment_environment\", service_name=~\"$service_name\"}[$__rate_interval])) * 0)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
