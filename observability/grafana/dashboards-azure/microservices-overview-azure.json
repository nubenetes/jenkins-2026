      "title": "Microservices Services - $deployment_environment",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "HTTP server request rate per service (Micrometer/OTel metric http_server_request_duration_seconds_count, exported by the Spring Boot Actuator + OTel Java agent auto-instrumentation - see the Helm chart values in the GitOps config repository), split by service_name and deployment_environment (stable=main branch in namespace microservices, develop=develop branch in namespace microservices-develop).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15
          },
          "unit": "reqps",
          "links": [
            {
              "targetBlank": true,
              "title": "Traces for ${series.labels.service_name}",
              "url": "/explore?left=%7B%22datasource%22%3A%20%22%24%7BDS_TEMPO%7D%22%2C%20%22queries%22%3A%20%5B%7B%22refId%22%3A%20%22A%22%2C%20%22query%22%3A%20%22%7Bresource.service.name%20%3D%20%5C%22%24%7B__series.labels.service_name%7D%5C%22%20%26%26%20resource.deployment.environment%20%3D%20%5C%22%24deployment_environment%5C%22%7D%22%2C%20%22queryType%22%3A%20%22traceql%22%7D%5D%2C%20%22range%22%3A%20%7B%22from%22%3A%20%22%24%7B__from%7D%22%2C%20%22to%22%3A%20%22%24%7B__to%7D%22%7D%7D"
            },
            {
              "targetBlank": true,
              "title": "Logs for ${series.labels.service_name}",
              "url": "/explore?left=%7B%22datasource%22%3A%20%22%24%7BDS_LOKI%7D%22%2C%20%22queries%22%3A%20%5B%7B%22refId%22%3A%20%22A%22%2C%20%22expr%22%3A%20%22%7Bk8s_namespace_name%3D%5C%22%24namespace%5C%22%7D%20%7C%20json%20%7C%20line_format%20%5C%22%7B%7B%20if%20.message%20%7D%7D%7B%7B%20.message%20%7D%7D%7B%7B%20else%20if%20.msg%20%7D%7D%7B%7B%20.msg%20%7D%7D%7B%7B%20else%20%7D%7D%7B%7B%20__line__%20%7D%7D%7B%7B%20end%20%7D%7D%5C%22%20%7C%20service_name%20%3D%20%5C%22%24%7B__series.labels.service_name%7D%5C%22%22%7D%5D%2C%20%22range%22%3A%20%7B%22from%22%3A%20%22%24%7B__from%7D%22%2C%20%22to%22%3A%20%22%24%7B__to%7D%22%7D%7D"
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (service_name, http_response_status_code) (rate(http_server_request_duration_seconds_count{deployment_environment=\"$deployment_environment\", service_name=~\"$service_name\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} [{{http_response_status_code}}]",
          "refId": "A"
        }
      ],
      "title": "HTTP Request Rate by Service",
      "type": "timeseries"
    },
