            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "100 * (sum(rate(http_server_request_duration_seconds_count{deployment_environment=\"$deployment_environment\", service_name=~\"$service_name\", http_response_status_code=~\"5..\"}[$__rate_interval])) or vector(0)) / sum(rate(http_server_request_duration_seconds_count{deployment_environment=\"$deployment_environment\", service_name=~\"$service_name\"}[$__rate_interval]))",
