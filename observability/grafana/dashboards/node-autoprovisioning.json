      "description": "The elasticity signal: Spot nodes scale up during CI builds and consolidate back toward 0 between them; the static pool stays flat.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "stepAfter", "lineWidth": 2, "showPoints": "never", "stacking": { "group": "A", "mode": "none" } }, "unit": "none", "min": 0 }, "overrides": [] },
      "options": { "legend": { "calcs": ["min", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "editorMode": "code", "expr": "count(kube_node_spec_taint{key=\"cloud.google.com/gke-spot\"}) or vector(0)", "legendFormat": "Spot (NAP)", "range": true, "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "editorMode": "code", "expr": "count(kube_node_info) - (count(kube_node_spec_taint{key=\"cloud.google.com/gke-spot\"}) or vector(0))", "legendFormat": "Static pool", "range": true, "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "editorMode": "code", "expr": "count(kube_node_info)", "legendFormat": "Total", "range": true, "refId": "C" }
      ]
    }
