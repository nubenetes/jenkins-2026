{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "PetClinic Services - $deployment_environment",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "HTTP server request rate per service (Micrometer/OTel metric http_server_duration_milliseconds_count, exported by the Spring Boot Actuator + OTel Java agent auto-instrumentation - see helm/petclinic/templates/instrumentation.yaml), split by service_name and deployment_environment (stable=master branch in namespace petclinic, develop=develop branch in namespace petclinic-develop).",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (service_name, http_status_code) (rate(http_server_duration_milliseconds_count{deployment_environment=\"$deployment_environment\"}[5m]))",
          "legendFormat": "{{service_name}} [{{http_status_code}}]",
          "refId": "A"
        }
      ],
      "title": "HTTP Request Rate by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "5xx response rate per service - rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[5m]).",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "reqps" },
        "overrides": [
          {
            "matcher": { "id": "byType", "options": "number" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (service_name) (rate(http_server_duration_milliseconds_count{deployment_environment=\"$deployment_environment\", http_status_code=~\"5..\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "title": "5xx Error Rate by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p95 server-side latency per service - histogram_quantile over http_server_duration_milliseconds_bucket.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10 }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(http_server_duration_milliseconds_bucket{deployment_environment=\"$deployment_environment\"}[5m])))",
          "legendFormat": "{{service_name}} p95",
          "refId": "A"
        }
      ],
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "JVM heap usage per service - jvm_memory_used_bytes{area=\"heap\"}.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "stacking": { "mode": "normal" } }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (service_name) (jvm_memory_used_bytes{deployment_environment=\"$deployment_environment\", area=\"heap\"})",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "title": "JVM Heap Usage by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "panels": [],
      "title": "Traces & Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
      "description": "Recent traces across all PetClinic services for the selected environment. Each request through petclinic-angular -> api-gateway -> downstream microservices is a single trace (W3C traceparent propagated end-to-end, see resources/angular/otel-web.js and helm/petclinic/templates/instrumentation.yaml).",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "filters": [
            {
              "id": "env",
              "operator": "=",
              "scope": "resource",
              "tag": "deployment.environment",
              "value": ["$deployment_environment"],
              "valueType": "string"
            }
          ],
          "limit": 20,
          "queryType": "traceqlSearch",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "PetClinic Traces",
      "type": "traces"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "description": "Application logs for the selected environment's namespace (petclinic / petclinic-develop). Lines containing trace_id=<hex> can be opened directly in Tempo via the Loki datasource's derived field.",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 27 },
      "id": 6,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{k8s_namespace_name=~\"petclinic.*\"} | json | line_format \"{{.message}}\"",
          "refId": "A"
        }
      ],
      "title": "PetClinic Pod Logs",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
