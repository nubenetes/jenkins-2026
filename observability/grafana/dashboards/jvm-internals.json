      "panels": [],
      "title": "Garbage Collection",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Seconds spent in GC per second (\u2192 a value near 1 means the app is GC-bound). Grouped by collector (SerialGC: Copy/MarkSweepCompact; G1: G1 Young/Old).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 25
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (service_name, jvm_gc_name) (rate(jvm_gc_duration_seconds_sum{k8s_namespace_name=\"$namespace\", service_name=~\"$service_name\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} {{jvm_gc_name}}",
          "refId": "A"
        }
      ],
      "title": "GC time rate (per collector)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Collections per second. Frequent young + rising old collections = heap pressure.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 25
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (service_name, jvm_gc_name) (rate(jvm_gc_duration_seconds_count{k8s_namespace_name=\"$namespace\", service_name=~\"$service_name\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} {{jvm_gc_name}}",
          "refId": "A"
        }
      ],
      "title": "GC frequency (per collector)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Stop-the-world pause duration. SerialGC pauses grow with heap; G1 keeps them bounded \u2014 compare before/after the GC switch.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 25
      },
      "id": 8,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.95, sum by (le, service_name, jvm_gc_name) (rate(jvm_gc_duration_seconds_bucket{k8s_namespace_name=\"$namespace\", service_name=~\"$service_name\"}[$__rate_interval])))",
          "legendFormat": "{{service_name}} {{jvm_gc_name}} p95",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "histogram_quantile(0.99, sum by (le, service_name, jvm_gc_name) (rate(jvm_gc_duration_seconds_bucket{k8s_namespace_name=\"$namespace\", service_name=~\"$service_name\"}[$__rate_interval])))",
          "legendFormat": "{{service_name}} {{jvm_gc_name}} p99",
          "refId": "B"
        }
      ],
      "title": "GC pause p95 / p99",
      "type": "timeseries"
    },
