      "title": "Heap memory",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Per-generation heap usage (Eden / Survivor / Tenured). Stacked = total heap. Watch Tenured climbing without falling after GC \u2192 possible leak.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (service_name, jvm_memory_pool_name) (jvm_memory_used_bytes{k8s_namespace_name=\"$namespace\", service_name=~\"$service_name\", jvm_memory_type=\"heap\"})",
          "legendFormat": "{{service_name}} / {{jvm_memory_pool_name}}",
          "refId": "A"
        }
      ],
      "title": "Heap used by pool",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "used = live objects, committed = OS-reserved, max = -XX:MaxHeapSize (MaxRAMPercentage). used approaching max \u2192 GC pressure / OOM risk.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (service_name) (jvm_memory_used_bytes{k8s_namespace_name=\"$namespace\", service_name=~\"$service_name\", jvm_memory_type=\"heap\"})",
          "legendFormat": "{{service_name}} used",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (service_name) (jvm_memory_committed_bytes{k8s_namespace_name=\"$namespace\", service_name=~\"$service_name\", jvm_memory_type=\"heap\"})",
          "legendFormat": "{{service_name}} committed",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (service_name) (jvm_memory_limit_bytes{k8s_namespace_name=\"$namespace\", service_name=~\"$service_name\", jvm_memory_type=\"heap\"} > 0)",
          "legendFormat": "{{service_name}} max",
          "refId": "C"
        }
      ],
      "title": "Heap used vs committed vs limit",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Heap still used immediately after a collection = the true working set. A steadily rising floor here is the classic memory-leak signature.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 15
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (service_name) (jvm_memory_used_after_last_gc_bytes{k8s_namespace_name=\"$namespace\", service_name=~\"$service_name\", jvm_memory_type=\"heap\"})",
          "legendFormat": "{{service_name}} post-GC live set",
          "refId": "A"
        }
      ],
      "title": "Heap live-set after GC",
      "type": "timeseries"
    },
