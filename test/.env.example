# Copy to test/.env (gitignored), fill in real values, then:
#   set -a; source test/.env; set +a
#   ./test/e2e.sh
#
# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# GCP project ID with billing enabled - terraform/gke creates a throwaway
# VPC + GKE cluster (~3x e2-standard-4) here and destroys it again at the end
# of test/e2e.sh. See README.md "Cost" section for an estimate.
GCP_PROJECT_ID=my-gcp-project-id

# -----------------------------------------------------------------------------
# Optional - terraform/gke (defaults shown)
# -----------------------------------------------------------------------------
# GCP_REGION=europe-southwest1
# GCP_ZONE=europe-southwest1-a
# GCP_CLUSTER_NAME=jenkins-2026

# -----------------------------------------------------------------------------
# Optional - observability.mode override
# -----------------------------------------------------------------------------
# Default (config/config.yaml): grafana-cloud - requires
# observability/otel-collector/secret.yaml (copy from secret.example.yaml
# and fill in your Grafana Cloud OTLP credentials) to exist BEFORE running
# test/e2e.sh.
#
# For a fully self-contained run with no external accounts, use the in-cluster
# OSS stack instead:
# JENKINS2026_OBS_MODE=oss

# -----------------------------------------------------------------------------
# Optional - forwarded to scripts/01-namespaces.sh (jenkins-credentials Secret)
# -----------------------------------------------------------------------------
# Needed only if you want the Jenkins pipelines to actually push images /
# clone a private PetClinic fork. ghcr.io pulls and the public
# spring-petclinic repos work anonymously without these.
# REGISTRY_USERNAME=<github-username>
# REGISTRY_PASSWORD=<ghcr-token-with-write:packages>
# GIT_USERNAME=<github-username>
# GIT_TOKEN=<github-token>

# -----------------------------------------------------------------------------
# Optional - scripts/down.sh behaviour
# -----------------------------------------------------------------------------
# test/e2e.sh defaults this to "true" (the whole cluster is destroyed right
# after anyway). Set to "false" to keep namespaces if you interrupt the test
# and want to inspect them with the cluster still up.
# J2026_DELETE_NAMESPACES=true
