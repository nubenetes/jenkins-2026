# Secrets / generated credentials - never commit real values
observability/otel-collector/secret.yaml
observability/otel-collector/secret-managed-azure.yaml
observability/otel-collector/secret-managed-aws.yaml
**/secret.local.yaml
**/secret-*.local.yaml
*.env
.env*
!.env.example

# Logs produced by scripts/up.sh & down.sh
/logs/

# Runtime values overlays generated by scripts/04-jenkins.sh
.generated/

# Dashboard manifests generated at runtime by scripts/07-grafana-dashboards.sh
# (wrapped versions of observability/grafana/dashboards/*.json for gcx upload).
# The canonical source is observability/grafana/dashboards/ - never commit the
# generated output.
gcx_test/dashboards/

# Helm
**/charts/*.tgz
**/Chart.lock

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Local Claude Code settings (not part of the PoC)
.claude/

# kubeconfig dumps some people drop in repos by accident
kubeconfig*
*.kubeconfig

# Terraform (terraform/gke - test/e2e.sh's throwaway GKE cluster;
# terraform/bootstrap - one-time GitHub Actions WIF/state-bucket setup)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
terraform/gke/terraform.tfvars
terraform/bootstrap/terraform.tfvars
terraform/grafana-cloud-stack/terraform.tfvars
terraform/grafana-cloud-token/terraform.tfvars
terraform/gateway-bootstrap/terraform.tfvars
terraform/azure-managed-grafana/terraform.tfvars
terraform/aws-managed-grafana/terraform.tfvars

# Written by .github/workflows/gke-provision.yml / gke-decommission.yml /
# grafana-cloud-bootstrap.yml before `terraform init` to point at the GCS
# state bucket - never present in local/test/e2e.sh runs.
terraform/gke/backend_override.tf
terraform/grafana-cloud-token/backend_override.tf
terraform/grafana-cloud-stack/backend_override.tf
terraform/gateway-bootstrap/backend_override.tf
terraform/azure-managed-grafana/backend_override.tf
terraform/aws-managed-grafana/backend_override.tf
