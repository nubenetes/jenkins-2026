# Secrets / generated credentials - never commit real values
observability/otel-collector/secret.yaml
**/secret.local.yaml
*.env
.env*
!.env.example

# Logs produced by scripts/up.sh & down.sh
logs/

# Runtime values overlays generated by scripts/04-jenkins.sh
.generated/

# Helm
**/charts/*.tgz
**/Chart.lock

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Local Claude Code settings (not part of the PoC)
.claude/

# kubeconfig dumps some people drop in repos by accident
kubeconfig*
*.kubeconfig

# Terraform (terraform/gke - test/e2e.sh's throwaway GKE cluster;
# terraform/bootstrap - one-time GitHub Actions WIF/state-bucket setup)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
terraform/gke/terraform.tfvars
terraform/bootstrap/terraform.tfvars

# Written by .github/workflows/gke-provision.yml / gke-decommission.yml
# before `terraform init` to point terraform/gke at the GCS state bucket -
# never present in local/test/e2e.sh runs.
terraform/gke/backend_override.tf
